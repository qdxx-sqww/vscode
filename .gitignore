# Ignore dataset files
论文/data/MOT17/
*.jpg
*.png
*.jpeg
*.gif
*.bmp
*.tiff
*.tif
*.webp
*.svg
*.ico

# Ignore model weights and checkpoints
*.pth
*.pt
*.h5
*.hdf5
*.ckpt
*.pkl
*.pickle

# Ignore logs and temporary files
*.log
*.tmp
*.temp
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Ignore virtual environments
.venv/
venv/
env/

# Ignore OS generated files
.DS_Store
Thumbs.db

# Ignore build artifacts
build/
dist/
*.egg-info/

# Ignore test results
runs/
test/exp*/
